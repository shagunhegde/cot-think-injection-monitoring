# Copy this to .env and fill in your values.
# .env is gitignored — never commit real keys.
#
# ── Required for judge / monitor / generator calls (OpenRouter) ──────────────
OPENROUTER_API_KEY=sk-or-v1-...

# ── Required for subject model download (HuggingFace) ────────────────────────
# Run once:  huggingface-cli login --token hf_...
# OR set this env var (Colab Secrets recommended on Colab):
HF_TOKEN=hf_...

# ── Optional workspace overrides ─────────────────────────────────────────────
# COTIM_ROOT=/path/to/your/workspace      # default: ./workspace
# COTIM_COLAB_ROOT=/gdrive/MyDrive/cot-injection-monitoring   # default on Colab

# ── Offline testing (no API key needed) ──────────────────────────────────────
# COTIM_LLM_BACKEND=mock    # forces MockBackend; used by the test suite automatically
